# Server Configuration
PORT=5000
NODE_ENV=development

# PostgreSQL Database Configuration
# Option 1: Connection String (recommended)
DATABASE_URL=postgresql://postgres:password@localhost:5432/expense_tracker

# Option 2: Individual Parameters
DB_HOST=localhost
DB_PORT=5432
DB_NAME=expense_tracker
DB_USER=postgres
DB_PASSWORD=your_password_here

# For cloud hosting (Railway, Supabase, Neon):
# DATABASE_URL will be provided by the service automatically

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRE=7d

# CORS Configuration
CLIENT_URL=http://localhost:4200

# TrueLayer Open Banking
TRUELAYER_CLIENT_ID=your-truelayer-client-id
TRUELAYER_CLIENT_SECRET=your-truelayer-client-secret
TRUELAYER_SANDBOX=true
APP_URL=http://localhost:5000

# Encrypts stored bank tokens at rest (any random string, e.g. openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=change-me
